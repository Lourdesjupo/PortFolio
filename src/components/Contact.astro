---

---

<section id="contact" class="py-24 relative overflow-hidden">
    <div
        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-primary/10 rounded-full blur-[120px] -z-10"
    >
    </div>

    <header class="max-w-4xl mx-auto px-6 text-center reveal reveal-up">
        <h2
            class="text-4xl md:text-7xl font-black mb-10 text-light-text dark:text-white leading-tight"
        >
            ¿Quieres contactar conmigo <span class="gradient-text"
                >o colaborar con AstracodeLAB?</span
            >
        </h2>

        <p
            class="text-xl text-light-text/60 dark:text-white/60 mb-16 max-w-2xl mx-auto leading-relaxed text-justify"
        >
            Estoy abierta a nuevas oportunidades y colaboraciones. Si quieres
            charlar sobre diseño, desarrollo o simplemente saludar, ¡escríbeme!
        </p>
    </header>
    <section class="flex flex-wrap justify-center items-center gap-6 mb-20 px-6 text-center lg:gap-24">
        <a
            href="mailto:lourdes.jupo@gmail.com"
            class="flex flex-col items-center justify-center hover:border-primary/50 transition-all duration-500 group reveal reveal-up stagger-1"
        >
            <div
                class="mb-6 p-4 rounded-2xl bg-primary/10 text-primary w-fit group-hover:scale-110 group-hover:bg-primary group-hover:text-white transition-all duration-500"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-6 h-6"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m22 2-7 20-4-9-9-4Z"></path><path d="M22 2 11 13"
                    ></path></svg
                >
            </div>
            <h3 class="text-lg font-bold mb-1 text-light-text dark:text-white">
                Email
            </h3>
        </a>

        <a
            href='https://www.linkedin.com/in/lourdes-ju%C3%A1rez-porto-984392129/"'
            target="_blank"
            rel="noopener noreferrer"
            class=" hover:border-primary/50 transition-all duration-500 group reveal reveal-up stagger-2"
        >
            <div
                class="mb-6 p-4 rounded-2xl bg-secondary/10 text-secondary w-fit group-hover:scale-110 group-hover:bg-secondary group-hover:text-white transition-all duration-500"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-6 h-6"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                    ></path><rect width="4" height="12" x="2" y="9"
                    ></rect><circle cx="4" cy="4" r="2"></circle></svg
                >
            </div>
            <h3 class="text-lg font-bold mb-1 text-light-text dark:text-white">
                LinkedIn
            </h3>
        </a>

        <a
            href="https://github.com/Lourdesjupo"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:border-primary/50 transition-all duration-500 group reveal reveal-up stagger-3"
        >
            <div
                class="mb-6 p-4 rounded-2xl bg-accent/10 text-accent w-fit group-hover:scale-110 group-hover:bg-accent group-hover:text-white transition-all duration-500"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-6 h-6"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
                    ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
                >
            </div>
            <h3 class="text-lg font-bold mb-1 text-light-text dark:text-white">
                GitHub
            </h3>
        </a>
    </section>

    <footer
        class="mt-32 pt-12 border-t border-light-text/10 dark:border-white/10 text-sm text-light-text/40 dark:text-white/40 font-medium"
    >
        <p class="flex items-center justify-center ml-10">
            © {new Date().getFullYear()} — Diseñado y desarrollado con ❤️ por Lourdes
            Juárez
        </p>
    </footer>
</section>
