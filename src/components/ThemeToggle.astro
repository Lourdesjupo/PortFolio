---
---
<div class="flex items-center gap-2">
  <span class="text-[10px] font-bold tracking-tighter uppercase opacity-100 dark:opacity-50 dark:text-white transition-opacity">Light</span>
  <button 
    id="theme-toggle-btn"
    class="theme-toggle relative inline-flex h-6 w-11 items-center rounded-full bg-gray-300 dark:bg-primary/20 border-2 border-gray-400 dark:border-primary/50 transition-colors focus:outline-none shadow-[inset_0_2px_4px_rgba(0,0,0,0.1)] dark:shadow-[inset_0_2px_4px_rgba(0,0,0,0.4)] group"
    aria-label="Toggle dark mode"
  >
    <span 
      class="pointer-events-none inline-block h-4 w-4 transform rounded-full bg-white dark:bg-primary shadow-[0_2px_5px_rgba(0,0,0,0.2)] dark:shadow-[0_0_10px_oklch(0.7_0.2_250_/_0.8)] transition-transform duration-200 ease-in-out translate-x-1 dark:translate-x-6"
    ></span>
  </button>
  <span class="text-[10px] font-bold tracking-tighter uppercase opacity-50 dark:opacity-100 dark:text-primary transition-opacity">Dark</span>
</div>

<script is:inline>
  // Esta función se encarga de asignar el evento de click a todos los botones con la clase 'theme-toggle'
  const attachThemeEvents = () => {
    const buttons = document.querySelectorAll('.theme-toggle');
    
    buttons.forEach(btn => {
      // Usamos btn.onclick para asegurar que no se acumulen múltiples eventos iguales
      btn.onclick = () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      };
    });
  };

  // Ejecutamos inmediatamente
  attachThemeEvents();

  // Escuchamos el evento de Astro para volver a ejecutarlo tras navegaciones o cambios en el DOM
  document.addEventListener('astro:page-load', attachThemeEvents);
  document.addEventListener('astro:after-swap', attachThemeEvents);

  // También lo intentamos con un pequeño retraso por si el DOM tarda en actualizarse en modo dev
  setTimeout(attachThemeEvents, 100);
</script>
