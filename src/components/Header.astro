---
import { Image } from 'astro:assets';
import logo_ljp from '../assets/logo_ljp.png';
import ThemeToggle from './ThemeToggle.astro';
---

<header
	class='flex justify-between items-center mx-auto px-3 sm:px-10 py-3 sticky top-0 w-full xl:w-[1120px]
z-10 bg-white dark:bg-gray-900 drop-shadow-md rounded-lg'
>
	<Image class='rounded-full w-16 h12' src={logo_ljp} alt='ljp photo' />
	<nav class='flex flex-row items-center gap-x-6 sm:gap-x-10 opacity-80 sm:text-sm'>
		<a class='text-gray-700 hover:text-submarine-400 dark:text-gray-300 dark:hover:text-submarine-300 hover:font-semibold' href='#aboutme'>Sobre mí</a>
		<a class='text-gray-700 hover:text-submarine-400 dark:text-gray-300 dark:hover:text-submarine-300 hover:font-semibold' href='#projects'>Proyectos</a>
		<a class='text-gray-700 hover:text-submarine-400 dark:text-gray-300 dark:hover:text-submarine-300 hover:font-semibold' href='#contactform'>Contacto</a>
		<ThemeToggle />
	</nav>
</header>

