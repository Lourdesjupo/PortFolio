---
import Header from '../components/Header.astro';
import '@fontsource/onest/400.css'; // Defaults to weight 400.
interface Props {
	title: string;
	description: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang='es'>
	<head>
		<meta charset='UTF-8' />
		<meta name='description' content='Bienvenido/a al portafolio de Lourdes Juárez, desarrolladora web. ' />
		<meta name='viewport' content='width=device-width, initial-scale=1' />
		<link rel='icon' type='image' href='logo_ljp.png' />
		<meta name='generator' content={Astro.generator} />
		<title>{title}</title>
		<!-- Theme script to prevent flash -->
		<script is:inline>
			const theme = localStorage.getItem('theme') ||
				(window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			}
		</script>
		<!-- Google tag (gtag.js) -->
		<script async src='https://www.googletagmanager.com/gtag/js?id=G-HL4DNFGSWS'></script>
		<script>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				dataLayer.push(arguments);
			}
			gtag('js', new Date());
			gtag('config', 'G-HL4DNFGSWS');
		</script>
	</head>
	<body class='bg-white dark:bg-gray-950 w-full min-h-screen overflow-x-hidden'>
		<div class='relative h-full w-full bg-white dark:bg-gray-950'>
			<div
				class='absolute h-full w-full bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] dark:bg-[radial-gradient(#374151_1px,transparent_1px)] [background-size:16px_16px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_70%,transparent_100%)] dark:[mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_70%,transparent_100%)]'
			>
			</div>
		</div>
		<Header />
		<slot />
	</body>
</html>
<style is:global>
	:root {
		color-scheme: light dark;
	}
	html {
		font-family: 'onest', system-ui, sans-serif;
		scroll-behavior: smooth;
		width: 100%;
		max-width: 100vw;
	}
	body {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		width: 100%;
		max-width: 100vw;
		margin: 0;
		padding: 0;
	}
	*, *::before, *::after {
		box-sizing: border-box;
	}
</style>
